---
interface Props {
  path?: string;
  slugs?: string[];
  currentPage?: "home" | "journal" | "post";
}

const { path = "~", slugs = [], currentPage = "home" } = Astro.props;
---

<div id="command-input-container" class="mt-4">
  <div id="command-output" class="text-sm font-mono space-y-1 mb-2"></div>
  <div class="flex flex-wrap gap-x-2 font-mono text-sm items-center">
    <span id="command-prompt">
      <span class="text-[var(--color-terminal-command)]">guest</span><span class="text-[var(--color-terminal-muted)]">@</span><span class="text-[var(--color-terminal-command)]">mikemollick.com</span><span class="text-[var(--color-terminal-muted)]">:</span><span class="text-[var(--color-terminal-link)]">{path}</span><span class="text-[var(--color-terminal-muted)]">$</span>
    </span>
    <input
      id="command-input"
      type="text"
      class="bg-transparent border-none outline-none text-[var(--color-terminal-text)] font-mono text-sm flex-1 min-w-[120px] caret-[var(--color-terminal-text)]"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="Terminal command input"
    />
  </div>
  <p class="text-xs text-[var(--color-terminal-muted)] mt-2 opacity-60">hint: type 'help' for available commands</p>
</div>

<script is:inline define:vars={{ slugs, path, currentPage }}>
  const input = document.getElementById('command-input');
  const output = document.getElementById('command-output');
  let awaitingSudoPassword = false;

  // Command history (persisted in localStorage)
  const HISTORY_KEY = 'terminal-history';
  const HISTORY_MAX = 1000;
  let history = [];
  try { history = JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; } catch {}
  let historyIndex = history.length;
  let savedInput = '';

  function pushHistory(cmd) {
    if (cmd && (history.length === 0 || history[history.length - 1] !== cmd)) {
      history.push(cmd);
      if (history.length > HISTORY_MAX) history = history.slice(-HISTORY_MAX);
      try { localStorage.setItem(HISTORY_KEY, JSON.stringify(history)); } catch {}
    }
    historyIndex = history.length;
    savedInput = '';
  }

  const commands = {
    help: () => {
      return [
        '<span style="color: var(--color-terminal-muted)">Available commands:</span>',
        '  <a href="/" style="color: var(--color-terminal-link)">home</a> <span style="color: var(--color-terminal-muted)">- go to home page</span>',
        '  <a href="/journal" style="color: var(--color-terminal-link)">journal</a> <span style="color: var(--color-terminal-muted)">- read my writing</span>',
        '  <span style="color: var(--color-terminal-muted)">journal &lt;slug&gt; - read a blog post</span>',
        '  <a href="https://github.com/mmollick" target="_blank" rel="noopener" style="color: var(--color-terminal-link)">github</a> <span style="color: var(--color-terminal-muted)">- view my code</span>',
        '  <a href="https://www.linkedin.com/in/michaelmollick" target="_blank" rel="noopener" style="color: var(--color-terminal-link)">linkedin</a> <span style="color: var(--color-terminal-muted)">- connect with me</span>',
        '  <span style="color: var(--color-terminal-muted)">clear - clear terminal output</span>',
      ].join('\n');
    },
    home: () => { window.location.href = '/'; return null; },
    'cd ~': () => { window.location.href = '/'; return null; },
    'cd ..': () => {
      const parts = window.location.pathname.split('/').filter(Boolean);
      parts.pop();
      window.location.href = '/' + parts.join('/');
      return null;
    },
    journal: () => { window.location.href = '/journal'; return null; },
    'cd journal': () => { window.location.href = '/journal'; return null; },
    github: () => { window.open('https://github.com/mmollick', '_blank'); return '<span style="color: var(--color-terminal-muted)">Opening GitHub...</span>'; },
    linkedin: () => { window.open('https://www.linkedin.com/in/michaelmollick', '_blank'); return '<span style="color: var(--color-terminal-muted)">Opening LinkedIn...</span>'; },
    clear: () => { output.innerHTML = ''; return null; },
    whoami: () => [
      '<span style="color: var(--color-terminal-prompt); font-weight: 600;">Mike Mollick</span> — Product Engineer &amp; Founder',
      'Building <a href="https://clarify.ai" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">Clarify</a>, the AI native CRM.',
      '<span style="color: var(--color-terminal-muted)">Previously led engineering at <a href="https://www.linkedin.com/company/syrupofficial/posts/?feedView=all" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">Syrup</a> (defunct), worked with <a href="https://www.ycombinator.com/companies/truepill" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">Truepill</a> (YC17), <a href="https://zoominfo.com" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">ZoomInfo</a>, and co-founded <a href="https://neverbounce.com" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">NeverBounce</a> (Acq. by ZoomInfo). Got my start at the digital agencies Creavos (defunct) and <a href="https://www.theformgroup.com/" style="color: var(--color-terminal-link);" target="_blank" rel="noopener">FORM</a>.</span>',
    ].join('\n'),
  };

  const promptEl = document.getElementById('command-prompt');

  function triggerSudoPrompt() {
    addOutput(`<span style="color: var(--color-terminal-text)">[sudo] password for guest:</span>`);
    awaitingSudoPassword = true;
    input.type = 'password';
    promptEl.innerHTML = '<span style="color: var(--color-terminal-muted)">Password:</span>';
  }

  function lsOutput() {
    if (currentPage === 'journal' || currentPage === 'post') {
      if (slugs.length === 0) return '<span style="color: var(--color-terminal-muted)">(empty)</span>';
      return slugs.map(s =>
        `<span style="color: var(--color-terminal-command)">${s}.mdx</span>`
      ).join('\n');
    }
    // home
    return [
      '<span style="color: var(--color-terminal-command)">journal/</span>',
    ].join('\n');
  }

  function lsLongOutput() {
    if (currentPage === 'journal' || currentPage === 'post') {
      const lines = ['<span style="color: var(--color-terminal-muted)">total ' + slugs.length + '</span>'];
      slugs.forEach(s => {
        lines.push(
          '<span style="color: var(--color-terminal-muted)">-rw-r--r--  mike staff</span>  <span style="color: var(--color-terminal-command)">' + s + '.mdx</span>'
        );
      });
      return lines.join('\n');
    }
    // home
    return [
      '<span style="color: var(--color-terminal-muted)">total 1</span>',
      '<span style="color: var(--color-terminal-muted)">drwxr-xr-x  mike staff</span>  <span style="color: var(--color-terminal-command)">journal/</span>',
    ].join('\n');
  }

  function esc(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function addOutput(html) {
    const line = document.createElement('div');
    line.innerHTML = html;
    output.appendChild(line);
  }

  function addPromptLine(cmd) {
    addOutput(
      `<span style="color: var(--color-terminal-command)">guest</span><span style="color: var(--color-terminal-muted)">@</span><span style="color: var(--color-terminal-command)">mikemollick.com</span><span style="color: var(--color-terminal-muted)">:</span><span style="color: var(--color-terminal-link)">${path}</span><span style="color: var(--color-terminal-muted)">$</span> ${cmd}`
    );
  }

  input.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const cmd = input.value.trim();
    if (!cmd) return;

    // Handle sudo password prompt
    if (awaitingSudoPassword) {
      awaitingSudoPassword = false;
      input.type = 'text';
      promptEl.innerHTML = `<span style="color: var(--color-terminal-command)">guest</span><span style="color: var(--color-terminal-muted)">@</span><span style="color: var(--color-terminal-command)">mikemollick.com</span><span style="color: var(--color-terminal-muted)">:</span><span style="color: var(--color-terminal-link)">${path}</span><span style="color: var(--color-terminal-muted)">$</span>`;
      if (cmd === 'dobby') {
        addOutput(`<span style="color: var(--color-terminal-command)">You honor me sir</span>`);
      } else {
        addOutput(`<span style="color: var(--color-terminal-red)">Sorry, try again.</span>`);
        addOutput(`<span style="color: var(--color-terminal-red)">sudo: 3 incorrect password attempts</span>`);
      }
      input.value = '';
      return;
    }

    pushHistory(cmd);
    addPromptLine(cmd);
    input.value = '';

    const lower = cmd.toLowerCase().replace(/\s+/g, ' ');

    // ls commands
    if (lower === 'ls' || lower === 'ls .') {
      addOutput(`<pre style="white-space: pre-wrap; margin: 0;">${lsOutput()}</pre>`);
      return;
    }
    if (lower === 'ls -la' || lower === 'ls -al' || lower === 'ls -l' || lower === 'ls -la .' || lower === 'ls -al .') {
      addOutput(`<pre style="white-space: pre-wrap; margin: 0;">${lsLongOutput()}</pre>`);
      return;
    }

    // echo
    if (lower.startsWith('echo ') || lower === 'echo') {
      const text = cmd.slice(5);
      addOutput(`<span style="color: var(--color-terminal-text)">${text.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</span>`);
      return;
    }

    // Check for journal <slug> command
    if (lower.startsWith('journal ')) {
      const slug = lower.slice(8).trim().replace(/^journal\//, '').replace(/\.mdx$/, '');
      if (slugs.includes(slug)) {
        window.location.href = `/journal/${slug}`;
        return;
      }
      addOutput(`<span style="color: var(--color-terminal-red)">journal: ${esc(slug)}: No such entry</span>`);
      return;
    }

    // Normalize cd targets (strip trailing slashes, handle ../ variants)
    if (lower.startsWith('cd ')) {
      const target = lower.slice(3).trim().replace(/\/+$/, '');
      if (target === '..' || target === '~') {
        commands['cd ' + target]();
        return;
      }
      if (target === 'journal') {
        window.location.href = '/journal';
        return;
      }
      if (slugs.includes(target)) {
        window.location.href = `/journal/${target}`;
        return;
      }
      addOutput(`<span style="color: var(--color-terminal-red)">cd: ${esc(target)}: No such directory</span>`);
      return;
    }

    // sudo easter egg
    if (lower === 'sudo' || lower.startsWith('sudo ')) {
      triggerSudoPrompt();
      return;
    }

    // rm -rf easter egg
    if (lower.startsWith('rm ') && (lower.includes('-rf') || lower.includes('-r'))) {
      const ua = navigator.userAgent;
      const os = /Mac/.test(ua) ? 'Macintosh HD' : /Windows/.test(ua) ? 'C:\\' : /Linux/.test(ua) ? '/' : 'disk0';

      addOutput(`<span style="color: var(--color-terminal-red)">rm: descending into ${os}...</span>`);
      setTimeout(() => addOutput(`<span style="color: var(--color-terminal-red)">rm: operation terminated — permission denied</span>`), 700);
      return;
    }

    const handler = commands[cmd.toLowerCase()];
    if (handler) {
      const result = handler();
      if (result) {
        if (cmd.toLowerCase() === 'whoami') {
          addOutput(`<div style="padding-left: 1rem; border-left: 2px solid var(--color-terminal-border); margin: 0.5rem 0;"><div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.875rem;">${result.split('\n').map(l => `<p>${l}</p>`).join('')}</div></div>`);
        } else {
          addOutput(`<pre style="white-space: pre-wrap; margin: 0;">${result}</pre>`);
        }
      }
    } else {
      addOutput(`<span style="color: var(--color-terminal-red)">command not found: ${esc(cmd)}</span>`);
      addOutput(`<span style="color: var(--color-terminal-muted)">Type 'help' for available commands.</span>`);
    }
  });

  // History navigation (ArrowUp / ArrowDown) + Ctrl+U to clear
  input.addEventListener('keydown', (e) => {
    if (e.key === 'u' && e.ctrlKey) {
      e.preventDefault();
      input.value = '';
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (history.length === 0) return;
      if (historyIndex === history.length) savedInput = input.value;
      if (historyIndex > 0) {
        historyIndex--;
        input.value = history[historyIndex];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex < history.length - 1) {
        historyIndex++;
        input.value = history[historyIndex];
      } else if (historyIndex === history.length - 1) {
        historyIndex = history.length;
        input.value = savedInput;
      }
    }
  });

  // Tab completion
  const completableCommands = ['help', 'home', 'journal', 'github', 'linkedin', 'clear', 'whoami', 'ls', 'cd'];

  function getCompletions(text) {
    const parts = text.split(/\s+/);
    const cmd = parts[0].toLowerCase();

    // Complete the command itself
    if (parts.length === 1) {
      return completableCommands
        .filter(c => c.startsWith(cmd) && c !== cmd)
        .map(c => c);
    }

    // Complete arguments for journal, cd
    if ((cmd === 'journal' || cmd === 'cd') && parts.length === 2) {
      const arg = parts[1];

      let candidates = [];

      if (cmd === 'journal') {
        candidates = slugs.map(s => s + '.mdx');
      } else {
        candidates = currentPage === 'home' ? ['journal', '~', '..'] : ['..', '~', ...slugs];
      }

      return candidates.filter(c => c.startsWith(arg) && c !== arg);
    }

    return [];
  }

  function longestCommonPrefix(strings) {
    if (strings.length === 0) return '';
    let prefix = strings[0];
    for (let i = 1; i < strings.length; i++) {
      while (strings[i].indexOf(prefix) !== 0) {
        prefix = prefix.slice(0, -1);
      }
    }
    return prefix;
  }

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Tab') {
      e.preventDefault();
      const text = input.value;
      if (!text) return;

      const matches = getCompletions(text);
      if (matches.length === 0) return;

      const parts = text.split(/\s+/);

      if (matches.length === 1) {
        // Single match — complete it
        parts[parts.length - 1] = matches[0];
        input.value = parts.join(' ');
      } else {
        // Multiple matches — complete common prefix, show options
        const partial = parts[parts.length - 1];
        const prefix = longestCommonPrefix(matches);
        if (prefix.length > partial.length) {
          parts[parts.length - 1] = prefix;
          input.value = parts.join(' ');
        } else {
          // Show all options
          addPromptLine(text);
          addOutput(`<pre style="white-space: pre-wrap; margin: 0; color: var(--color-terminal-command)">${matches.join('  ')}</pre>`);
        }
      }
    }
  });

  // Focus input only if it's visible in the viewport
  function focusIfVisible() {
    const rect = input.getBoundingClientRect();
    if (rect.top >= 0 && rect.bottom <= window.innerHeight) {
      input.focus({ preventScroll: true });
    }
  }

  focusIfVisible();
  window.addEventListener('focus', focusIfVisible);

  // Focus input when clicking anywhere in terminal
  document.addEventListener('click', (e) => {
    if (!e.target.closest('a') && !e.target.closest('button') && !e.target.closest('details')) {
      input.focus();
    }
  });
</script>
