---
import TerminalWindow from "../layouts/TerminalWindow.astro";
import CommandNav from "../components/CommandNav.astro";
import CommandInput from "../components/CommandInput.astro";
import { getCollection } from "astro:content";
import { getCCStats, fmtTokens, getHeatmapData, buildHeatmapGrid } from "../lib/cc-stats";

const entries = await getCollection("blog", (entry) =>
  import.meta.env.PROD ? entry.data.isPublished : true,
);
const slugs = entries.map((e) => e.slug);
const ccStats = getCCStats();
const topModel = ccStats
  ? Object.entries(ccStats.modelBreakdown).sort((a, b) => b[1] - a[1])[0]?.[0] ?? "—"
  : null;
const statsDate = ccStats ? new Date(ccStats.asOf).toDateString() : new Date().toDateString();
const heatmapData = getHeatmapData();
const heatmap = heatmapData ? buildHeatmapGrid(heatmapData) : null;
---

<TerminalWindow
  description="Mike Mollick is a Product Engineer and Founder who has worked in startups from pre-seed through IPO."
  path="~"
>
  <!-- MOTD / login screen -->
  <div class="text-sm space-y-1 my-4 font-mono">
    <p class="text-[var(--color-terminal-text)]">
      Welcome to mikemollick.com v2.0.0 LTS (Darwin 24.3.0 arm64)
    </p>
    <br />
    <p class="text-[var(--color-terminal-muted)]">
      &nbsp;* Documentation:  <a href="/journal" class="text-[var(--color-terminal-link)] hover:underline">/journal</a>
    </p>
    <p class="text-[var(--color-terminal-muted)]">
      &nbsp;* Source:         <a href="https://github.com/mmollick" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">github.com/mmollick</a>
    </p>
    <p class="text-[var(--color-terminal-muted)]">
      &nbsp;* Work:           <a href="https://clarify.ai" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">clarify.ai</a>
    </p>
    <p class="text-[var(--color-terminal-muted)]">
      &nbsp;* Previously:     <a href="https://www.linkedin.com/company/syrupofficial/posts/?feedView=all" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">Syrup</a>,
      <a href="https://www.ycombinator.com/companies/truepill" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">Truepill</a>,
      <a href="https://zoominfo.com" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">ZoomInfo</a>,
      <a href="https://neverbounce.com" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">NeverBounce</a>,
      Creavos (Defunct),
      <a href="https://www.theformgroup.com/" class="text-[var(--color-terminal-link)] hover:underline" target="_blank" rel="noopener">FORM</a>
    </p>
    <br />
    <p class="text-[var(--color-terminal-muted)]">
      Claude Code usage as of {statsDate} (last 30 days)
    </p>
    <br />
    {ccStats ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-0.5">
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Sessions:</span>      {ccStats.totalSessions}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Prompts:</span>       {ccStats.totalPrompts}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Input tokens:</span>  {fmtTokens(ccStats.tokens.input)}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Output tokens:</span> {fmtTokens(ccStats.tokens.output)}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Cache read:</span>    {fmtTokens(ccStats.tokens.cache_read)}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Cache created:</span> {fmtTokens(ccStats.tokens.cache_creation)}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Top model:</span>     {topModel}
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Tool calls:</span>    {ccStats.totalToolCalls.toLocaleString()}
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-0.5">
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">System load:</span>  0.42
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Processes:</span>     142
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Usage of /:</span>    62.4% of 20GB
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Users logged in:</span> 1
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">Memory usage:</span>  71%
        </p>
        <p class="text-[var(--color-terminal-muted)]">
          <span class="text-[var(--color-terminal-text)]">IPv4:</span>          127.0.0.1
        </p>
      </div>
    )}

    {heatmap && (
      <div class="mt-3 overflow-x-auto">
        <br />
        <pre class="text-xs font-mono whitespace-pre" style="line-height:1.2;letter-spacing:0">{heatmap.lines.map((segments, i) => (
          <span>{segments.map(seg => (
            <span class={
              seg.style === "label"   ? "text-[var(--color-terminal-muted)]" :
              seg.style === "dot"     ? "text-[#1e2d3d]" :
              seg.style === "active1" ? "text-[#1e4a7a]" :
              seg.style === "active2" ? "text-[#1a6bbf]" :
              seg.style === "active3" ? "text-[#3b88e8]" :
                                        "text-[var(--color-terminal-link)]"
            }>{seg.text}</span>
          ))}{i < heatmap.lines.length - 1 ? "\n" : ""}</span>
        ))}</pre>
      </div>
    )}
  </div>

<CommandNav />

  <p class="text-sm text-[var(--color-terminal-muted)] mt-2">
    Last login: <span id="last-login">now</span>
  </p>

  <script>
    const key = 'mikemollick_last_visit';
    const prev = localStorage.getItem(key);
    if (prev) {
      document.getElementById('last-login').textContent = new Date(prev).toDateString();
    }
    localStorage.setItem(key, new Date().toISOString());
  </script>

  <CommandInput path="~" slugs={slugs} currentPage="home" />
</TerminalWindow>
