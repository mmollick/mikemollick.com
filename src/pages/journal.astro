---
import { getCollection } from "astro:content";
import TerminalWindow from "../layouts/TerminalWindow.astro";
import PromptLine from "../components/PromptLine.astro";
import OutputBlock from "../components/OutputBlock.astro";
import CommandInput from "../components/CommandInput.astro";

const entries = await getCollection("blog", (entry) =>
  import.meta.env.PROD ? entry.data.isPublished : true,
);

const sortedEntries = entries.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

function formatDate(date: Date): string {
  return date.toISOString().split("T")[0];
}
---

<TerminalWindow
  title="Journal"
  description="An incomplete compendium of my thoughts"
  path="~/journal"
>
  <PromptLine command="ls -la" path="~/journal" />
  <OutputBlock>
    <div class="text-sm my-3 font-mono overflow-x-auto">
      <p class="text-[var(--color-terminal-muted)] mb-1">total {sortedEntries.length}</p>
      <div class="space-y-0.5">
        <div class="flex gap-x-4 text-[var(--color-terminal-muted)]">
          <span class="shrink-0">drwxr-xr-x</span>
          <span class="shrink-0">guest mikemollick.com</span>
          <span class="shrink-0 text-[var(--color-terminal-amber)]">..</span>
          <a href="/" class="text-[var(--color-terminal-link)] hover:underline">→ ~</a>
        </div>
        {sortedEntries.map((entry) => (
          <div class="flex gap-x-4">
            <span class="shrink-0 text-[var(--color-terminal-muted)]">-rw-r--r--</span>
            <span class="shrink-0 text-[var(--color-terminal-muted)]">guest mikemollick.com</span>
            <span class="shrink-0 text-[var(--color-terminal-amber)]">{formatDate(entry.data.date)}</span>
            <a
              href={`/journal/${entry.slug}`}
              class="text-[var(--color-terminal-command)] hover:underline truncate"
            >
              {entry.slug}.mdx
            </a>
          </div>
        ))}
      </div>
    </div>
  </OutputBlock>

  <CommandInput path="~/journal" slugs={sortedEntries.map((e) => e.slug)} currentPage="journal" />
</TerminalWindow>
